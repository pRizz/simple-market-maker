{
  "name": "simple-market-maker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname ::",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/modules/db/migrate.ts",
    "verify": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.2",
    "next": "^16.2.4",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "tsx": "^4.20.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
